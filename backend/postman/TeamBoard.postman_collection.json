{
  "info": {
    "name": "TeamBoard Backend",
    "description": "GraphQL collection for TeamBoard auth, users, projects, and tasks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/graphql" },
    { "key": "accessToken", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation Register($input: RegisterDto!) {\n  register(registerInput: $input) {\n    accessToken\n    user {\n      id\n      email\n      name\n      role\n    }\n  }\n}",
            "variables": "{\n  \"input\": {\n    \"name\": \"Test User\",\n    \"email\": \"test@teamboard.local\",\n    \"password\": \"Password123!\"\n  }\n}"
          }
        },
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.data?.login?.accessToken) pm.collectionVariables.set('accessToken', json.data.login.accessToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation Login($input: LoginDto!) {\n  login(loginInput: $input) {\n    accessToken\n    user {\n      id\n      email\n      name\n      role\n    }\n  }\n}",
            "variables": "{\n  \"input\": {\n    \"email\": \"ada@teamboard.local\",\n    \"password\": \"Password123!\"\n  }\n}"
          }
        },
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query Me {\n  me {\n    id\n    email\n    name\n    role\n  }\n  currentUser {\n    id\n    email\n    name\n    role\n    jobTitle\n    timezone\n  }\n}",
            "variables": "{}"
          }
        },
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "User - Update Current User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation UpdateCurrentUser($input: UpdateUserDto!) {\n  updateCurrentUser(userInput: $input) {\n    id\n    name\n    bio\n    jobTitle\n    timezone\n  }\n}",
            "variables": "{\n  \"input\": {\n    \"bio\": \"Building TeamBoard\",\n    \"jobTitle\": \"Backend Engineer\",\n    \"timezone\": \"Africa/Lagos\"\n  }\n}"
          }
        },
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "Project - Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.data?.createProject?.id) pm.collectionVariables.set('projectId', json.data.createProject.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation CreateProject($input: CreateProjectDto!) {\n  createProject(projectInput: $input) {\n    id\n    name\n    status\n    visibility\n    color\n    tags\n    progress\n  }\n}",
            "variables": "{\n  \"input\": {\n    \"name\": \"Postman Project\",\n    \"description\": \"Created from Postman\",\n    \"status\": \"ACTIVE\",\n    \"visibility\": \"TEAM\",\n    \"color\": \"#2563eb\",\n    \"tags\": [\"api\", \"postman\"]\n  }\n}"
          }
        },
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "Project - List",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "const firstProject = json.data?.projects?.[0];",
              "if (firstProject?.id) pm.collectionVariables.set('projectId', firstProject.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query Projects {\n  projects {\n    id\n    name\n    description\n    status\n    visibility\n    tags\n    progress\n    dueDate\n  }\n}",
            "variables": "{}"
          }
        },
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "Project - Update",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation UpdateProject($input: UpdateProjectDto!) {\n  updateProject(projectInput: $input) {\n    id\n    name\n    status\n    progress\n  }\n}",
            "variables": "{\n  \"input\": {\n    \"id\": \"{{projectId}}\",\n    \"status\": \"ON_HOLD\",\n    \"progress\": 55\n  }\n}"
          }
        },
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "Task - Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.data?.createTask?.id) pm.collectionVariables.set('taskId', json.data.createTask.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation CreateTask($input: CreateTaskDto!) {\n  createTask(taskInput: $input) {\n    id\n    title\n    status\n    priority\n    labels\n    estimateMinutes\n    order\n  }\n}",
            "variables": "{\n  \"input\": {\n    \"projectId\": \"{{projectId}}\",\n    \"title\": \"Postman task\",\n    \"description\": \"Created from Postman\",\n    \"status\": \"TODO\",\n    \"priority\": \"HIGH\",\n    \"labels\": [\"api\"],\n    \"estimateMinutes\": 90,\n    \"order\": 1\n  }\n}"
          }
        },
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "Task - List By Project",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "const firstTask = json.data?.tasks?.[0];",
              "if (firstTask?.id) pm.collectionVariables.set('taskId', firstTask.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query Tasks($projectId: ID!) {\n  tasks(projectId: $projectId) {\n    id\n    title\n    status\n    priority\n    labels\n    dueDate\n    completedAt\n  }\n}",
            "variables": "{\n  \"projectId\": \"{{projectId}}\"\n}"
          }
        },
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "Task - Update",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation UpdateTask($input: UpdateTaskDto!) {\n  updateTask(taskInput: $input) {\n    id\n    title\n    status\n    completedAt\n  }\n}",
            "variables": "{\n  \"input\": {\n    \"id\": \"{{taskId}}\",\n    \"status\": \"DONE\",\n    \"completedAt\": \"2026-06-23T12:00:00.000Z\"\n  }\n}"
          }
        },
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "Task - Delete",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation DeleteTask($id: ID!) {\n  deleteTask(id: $id)\n}",
            "variables": "{\n  \"id\": \"{{taskId}}\"\n}"
          }
        },
        "url": "{{baseUrl}}"
      }
    }
  ]
}
