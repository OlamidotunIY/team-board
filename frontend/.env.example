# Frontend environment example for Vite
# Copy to .env or .env.local in the frontend/ folder and adjust as needed

# HTTP GraphQL endpoint the client will use.
VITE_GRAPHQL_URL=http://localhost:3100/graphql

# WebSocket URL for subscriptions (optional)
NEXT_PUBLIC_GRAPHQL_WS_URL=ws://localhost:3100/graphql

# Application version string used in client headers
NEXT_PUBLIC_APP_VERSION=web-unknown
